#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
QUARTO_VERSION="1.9.38"
LOCAL_QUARTO="$ROOT/.tools/quarto/$QUARTO_VERSION/bin/quarto"
TMP_QUARTO="/private/tmp/math435-quarto-cli-$QUARTO_VERSION"
TMP_PROJECT="/private/tmp/math435-render"
TMP_HOME="/private/tmp/math435-quarto-home"

export HOME="$ROOT/.quarto/home"
mkdir -p "$HOME"

patch_arm64_sass() {
  local quarto_root="$1"
  local x86_sass="$quarto_root/bin/tools/x86_64/dart-sass"
  local arm_sass="../aarch64/dart-sass"
  local arm_sass_bin="$quarto_root/bin/tools/aarch64/dart-sass/sass"

  if [[ -x "$arm_sass_bin" ]] && "$arm_sass_bin" --version >/dev/null 2>&1 && [[ -d "$x86_sass" && ! -L "$x86_sass" ]]; then
    mv "$x86_sass" "$x86_sass.x86_64"
    ln -s "$arm_sass" "$x86_sass"
  fi
}

use_arm64_deno_if_available() {
  local quarto_root="$1"
  local deno_bin="$quarto_root/bin/tools/aarch64/deno"
  if [[ -x "$deno_bin" ]] && "$deno_bin" --version >/dev/null 2>&1; then
    export QUARTO_DENO="$deno_bin"
    export DENO_DOM_PLUGIN="$quarto_root/bin/tools/aarch64/deno_dom/libplugin.dylib"
  fi
}

run_from_no_space_mirror() {
  local command="${1:-}"
  if [[ "$command" != "render" && "$command" != "preview" ]]; then
    return 1
  fi

  if [[ "$ROOT" != *" "* && "$ROOT" != *":"* ]]; then
    return 1
  fi

  mkdir -p "$TMP_PROJECT" "$TMP_QUARTO" "$TMP_HOME"
  rsync -a --delete \
    --exclude .git \
    --exclude .tools \
    --exclude .quarto \
    --exclude _site \
    "$ROOT"/ "$TMP_PROJECT"/

  if [[ ! -x "$TMP_QUARTO/bin/quarto" ]]; then
    if [[ ! -f "$ROOT/.tools/downloads/quarto-$QUARTO_VERSION-macos.tar.gz" ]]; then
      return 1
    fi
    tar -xzf "$ROOT/.tools/downloads/quarto-$QUARTO_VERSION-macos.tar.gz" -C "$TMP_QUARTO"
  fi

  patch_arm64_sass "$TMP_QUARTO"

  use_arm64_deno_if_available "$TMP_QUARTO"
  export HOME="$TMP_HOME"

  local status=0
  (cd "$TMP_PROJECT" && "$TMP_QUARTO/bin/quarto" "$@") || status=$?
  if [[ "$status" -ne 0 ]]; then
    return "$status"
  fi

  if [[ "$command" == "render" && -d "$TMP_PROJECT/_site" ]]; then
    rsync -a --delete "$TMP_PROJECT/_site"/ "$ROOT/_site"/
  fi
  return 0
}

if [[ "${1:-}" == "render" || "${1:-}" == "preview" ]]; then
  run_from_no_space_mirror "$@"
  exit $?
fi

patch_arm64_sass "$ROOT/.tools/quarto/$QUARTO_VERSION"

use_arm64_deno_if_available "$ROOT/.tools/quarto/$QUARTO_VERSION"

if [[ -x "$LOCAL_QUARTO" ]]; then
  exec "$LOCAL_QUARTO" "$@"
fi

if command -v quarto >/dev/null 2>&1; then
  exec quarto "$@"
fi

echo "Quarto was not found. Install Quarto or restore the local .tools/quarto install." >&2
exit 127
